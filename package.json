  "bugs": {
    "url": "https://github.com/mnavarrosqa/nodepanelg/issues"
  },
  "homepage": "https://github.com/mnavarrosqa/nodepanelg#readme",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.3",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "cross-env": "^7.0.2",
    "tsx": "^4.19.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
